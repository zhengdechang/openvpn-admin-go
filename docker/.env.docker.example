# Docker 部署环境变量
# 复制为 .env（与 docker-compose.yml 同目录）并按需修改

# Docker Hub 镜像前缀
DOCKERHUB_USERNAME=codedevin

# 对外端口（host 侧）
FRONTEND_PORT=3043
BACKEND_PORT=8085
OPENVPN_PORT=1194

# 安全
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 超级管理员（仅当数据库中尚无超级管理员时，启动会用它创建；为空则启动失败）
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password
# SUPERADMIN_NAME=Super Admin

# PostgreSQL 数据库配置（backend 通过服务名 postgres 连接，端口 5432）
# 也可直接设置 DATABASE_URL 覆盖下列分项（database.go 优先读取 DATABASE_URL）：
# DATABASE_URL=postgres://openvpn:please-change-pass@postgres:5432/openvpn?sslmode=disable
DB_NAME=openvpn
DB_USER=openvpn
DB_PASSWORD=please-change-pass

# 时区
TZ=Asia/Shanghai
