# 后端本地运行环境变量（go run main.go）
# 复制为 .env 并按需修改

# PostgreSQL 数据库连接
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=openvpn
DB_PASSWORD=openvpn
DB_NAME=openvpn
# 可选：直接提供完整 DSN 覆盖上面的离散变量
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/openvpn?sslmode=disable

# 安全
JWT_SECRET=change-me-in-production

# 超级管理员（仅当数据库中尚无超级管理员时，启动会用它创建；为空则启动失败）
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password
# 可选，默认 "Super Admin"
# SUPERADMIN_NAME=Super Admin

# 运行模式
GIN_MODE=debug
