client
dev tun
proto tcp
remote openvpn-admin 4500
resolv-retry 5
nobind
persist-key
persist-tun
remote-cert-tls server
data-ciphers AES-256-GCM:AES-128-GCM:CHACHA20-POLY1305:AES-256-CBC
auth SHA256
key-direction 1
tls-client
tls-version-min 1.2
auth-nocache

push "route 10.10.100.0 255.255.255.0"

push "route 10.10.98.0 255.255.255.0"

